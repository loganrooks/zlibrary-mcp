{
  "mode": "yolo",
  "depth": "comprehensive",
  "parallelization": true,
  "commit_docs": true,
  "model_profile": "quality",
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true
  },
  "health_check": {
    "frequency": "milestone-only",
    "stale_threshold_days": 7,
    "blocking_checks": false
  },
  "devops": {
    "ci_provider": "none",
    "deploy_target": "none",
    "commit_convention": "freeform",
    "environments": []
  },
  "gsd_reflect_version": "1.13.0",
  "automation": {
    "reflection": {
      "auto_reflect": false,
      "threshold_phases": 3,
      "min_signals": 5,
      "phases_since_last_reflect": 1,
      "last_reflect_at": null
    }
  }
}
