{
  "name": "zlibrary-mcp",
  "version": "1.2.0",
  "description": "Z-Library MCP server for AI assistants (UV-based)",
  "main": "dist/index.js",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./lib/*": "./dist/lib/*"
  },
  "bin": {
    "zlibrary-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node scripts/validate-python-bridge.js",
    "validate": "node scripts/validate-python-bridge.js",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --forceExit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern 'integration/bridge' --forceExit",
    "test:integration:live": "TEST_LIVE=true npm run test:integration",
    "test:e2e": "docker compose -f docker-compose.test.yml up --build --abort-on-container-exit --exit-code-from e2e-test",
    "test:e2e:local": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern 'e2e' --forceExit",
    "prepublishOnly": "npm run build",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write",
      "bash -c 'tsc --noEmit'"
    ],
    "*.py": [
      "uv run ruff check --fix",
      "uv run ruff format"
    ]
  },
  "keywords": [
    "mcp",
    "zlibrary",
    "ai",
    "roocode",
    "cline"
  ],
  "author": "loganrooks",
  "license": "MIT",
  "files": [
    "dist/",
    "lib/",
    "zlibrary/",
    "!zlibrary/src/test.py",
    "pyproject.toml",
    "uv.lock",
    "setup-uv.sh",
    "!**/__pycache__/",
    "!**/*.pyc"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "env-paths": "^4.0.0",
    "python-shell": "^5.0.0",
    "zod": "^3.25.76"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loganrooks/zlibrary-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/loganrooks/zlibrary-mcp/issues"
  },
  "homepage": "https://github.com/loganrooks/zlibrary-mcp#readme",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.12",
    "@types/mock-fs": "^4.13.4",
    "@types/node": "^22.0.0",
    "@types/sinon": "^17.0.3",
    "@types/supertest": "^6.0.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "mock-fs": "^5.2.0",
    "nock": "^13.4.0",
    "prettier": "^3.8.1",
    "sinon": "^17.0.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.3.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.57.1"
  }
}
